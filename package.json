{
  "name": "the-negotiator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "arch:check": "depcruise --config .dependency-cruiser.cjs src",
    "docs:check": "node scripts/check-docs-freshness.mjs",
    "ci": "npm run lint && npm run typecheck && npm run arch:check && npm run test && npm run build"
  },
  "dependencies": {
    "@elevenlabs/react": "^1.10.1",
    "@supabase/supabase-js": "^2.110.7",
    "next": "^15.5.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
