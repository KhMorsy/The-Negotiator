# The Negotiator — env template (no secrets)
# Copy to .env.local for local development. CI uses fake adapters and needs none of these.

# Supabase (T1 persistence / T2 realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (planner / parser / vision) — never required in CI
OPENAI_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Feature flags
USE_SIMULATED_TELEPHONY=true
